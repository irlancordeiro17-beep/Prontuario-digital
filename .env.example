# ============================================================
# PRONTUÁRIO SOCIAL — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# NUNCA commite .env.local no GitHub
# ============================================================

# --- NextAuth ---
AUTH_SECRET=                        # gere com: openssl rand -base64 32
AUTH_URL=http://localhost:3000       # em produção: https://seu-dominio.vercel.app

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=           # https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=      # chave pública anon
SUPABASE_SERVICE_ROLE_KEY=          # chave privada service_role (apenas servidor)

# --- Database (Prisma via Supabase) ---
DATABASE_URL=                       # postgresql://postgres:[senha]@db.xxxx.supabase.co:5432/postgres
DIRECT_URL=                         # postgresql://postgres:[senha]@db.xxxx.supabase.co:5432/postgres

# --- Resend (email recuperação de senha) ---
RESEND_API_KEY=                     # re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@seu-dominio.com.br

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Prontuário Social"
